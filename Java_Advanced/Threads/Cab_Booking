class NoCabAvailableException extends Exception{
	public NoCabAvailableException(String message){
		super(message);
	}
}

class Cab{
	int cabs = 3;
	synchronized void bookingCab(String name)throws NoCabAvailableException{
		
		if(cabs == 0){
			throw new NoCabAvailableException("Sorry!!!" + name + " All cabs are booked!!! No cab available now ");
		}
		else{
			System.out.println("Welcom to SamSarah'h ride!!!");
			System.out.println("Cab booked!!!" + name + " Got the ride");
			cabs--;
			
		}
		
		
		
		
		
		// if(cabs > 0){
			// System.out.println("Welcom to SamSarah'h ride!!!");
			// System.out.println("Cab booked!!!" + name + " Got the ride");
			// cabs--;
		// }else{
			// System.out.println("Sorry!!!" + name + " All cabs are booked!!! No cab available now ");
		// }
	}
	
}
class Customer extends Thread{
	
	Cab c;
	String name;
	Customer(Cab c, String name){
		this.c = c;
		this.name = name;
		
	}

	public void run(){
		try{
			c.bookingCab(name);
		}
		catch(NoCabAvailableException e){
		    e.printStackTrace();
	    }
		    
	    

	}
	
	
}

class Sample{
	public static void main(String[] args)throws InterruptedException{
		Cab obj = new Cab();
		
		Customer t1 = new Customer(obj, "Sarah");
		Customer t2 = new Customer(obj, "Sam");
		Customer t3 = new Customer(obj, "Aditi");
		Customer t4 = new Customer(obj, "Ramya");
		
		
		
		t1.start();
		t2.start();
		t3.start();
		t4.start();
		
		t1.join();
		t2.join();
		t3.join();
		t4.join();
		
		
		
	}
}
